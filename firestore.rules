rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin';
    }

    // Helper function to get current user's data
    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
    }

    // Users collection rules
    match /users/{email} {
      // Allow read of user document if:
      // 1. User is reading their own document (email matches)
      // 2. User is an admin
      allow read: if isAuthenticated() && 
        (email == request.auth.token.email || isAdmin());
      
      // Allow create if:
      // 1. The document ID matches the user's email
      // 2. User is an admin OR this is the first user in the system
      allow create: if isAuthenticated() &&
        (email == request.auth.token.email || isAdmin() || 
        !exists(/databases/$(database)/documents/users/__first_user__));
      
      // Allow update if:
      // 1. User is updating their own document (but can't change role)
      // 2. User is an admin
      allow update: if isAuthenticated() &&
        (email == request.auth.token.email && 
         request.resource.data.role == resource.data.role || 
         isAdmin());
      
      // Only admin can delete users
      allow delete: if isAdmin();
    }

    // Attendance collection rules
    match /attendance/{email} {
      // Users can read their own attendance
      // Admins can read all attendance
      allow read: if isAuthenticated() &&
        (email == request.auth.token.email || isAdmin());
      
      // Users can create their own attendance
      // Admins can create attendance for anyone
      allow create: if isAuthenticated() &&
        (email == request.auth.token.email || isAdmin());
      
      // Users can update their own attendance of the same day
      // Admins can update any attendance
      allow update: if isAuthenticated() &&
        (email == request.auth.token.email || isAdmin());
      
      // Only admins can delete attendance records
      allow delete: if isAdmin();
    }

    // Leave Types collection rules
    match /leaveTypes/{leaveType} {
      // All authenticated users can read leave types
      allow read: if isAuthenticated();
      // Only admins can modify leave types
      allow write: if isAdmin();
    }

    // Leave Calendar collection rules
    match /leaveCalendar/{date} {
      // All authenticated users can read calendar
      allow read: if isAuthenticated();
      // Only admins can modify calendar
      allow write: if isAdmin();
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
